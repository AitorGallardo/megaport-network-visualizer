# Copy to .env.local to use the real Megaport Staging API.
# Leave unset (or VITE_MEGAPORT_SOURCE=mock) to run on bundled mock data,
# which is shaped exactly like a real GET /v2/products response.
VITE_MEGAPORT_SOURCE=mock

# Documented Megaport endpoints (Staging shown; swap to prod if you must):
VITE_MEGAPORT_BASE_URL=https://api-staging.megaport.com
VITE_MEGAPORT_AUTH_URL=https://auth-m2m-staging.megaport.com/oauth2/token

# Option A — let the app do the OAuth2 client-credentials exchange (recommended):
# Create an API key in Portal → Tools → API Key Generator. Never commit these.
VITE_MEGAPORT_API_KEY=
VITE_MEGAPORT_API_SECRET=

# Option B — paste a pre-generated bearer token instead of key/secret:
VITE_MEGAPORT_TOKEN=
