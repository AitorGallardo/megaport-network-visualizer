{
  "name": "megaport-network-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An interactive network topology view for Megaport services (Ports, VXCs, MCR, MVE, Cloud Connections) — a proof-of-work demo built in Megaport's stack. By Aitor Gallardo.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.59.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "vue": "^3.5.12"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vue-tsc": "^2.2.12"
  }
}
